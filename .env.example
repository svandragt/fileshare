USERNAME=admin
# PASSWORD must be a bcrypt hash — generate with:
#   php -r "echo password_hash('yourpassword', PASSWORD_BCRYPT);"
PASSWORD=$2y$12$replacethiswitharealhash

# Random secret for the /cron endpoint — generate with:
#   php -r "echo bin2hex(random_bytes(32));"
CRON_SECRET=replacethiswitharandomsecret
